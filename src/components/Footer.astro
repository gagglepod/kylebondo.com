---
import { Icon } from "astro-icon";
// component from flowbite
---

<footer class="p-4 bg-white sm:p-6 dark:bg-zinc-900 mx-auto max-w-6xl sticky top-[100vh] underline-offset-2">
  <div class="md:flex md:justify-between">
    <div class="mb-6 md:mb-0 flex flex-col">
      <a href="/" class="flex items-center" aria-label="mountain icon">
        <Icon name="lucide:mountain-snow" class="w-8 h-8" />
        <span class="self-center text-2xl font-bold whitespace-nowrap dark:text-white ml-3 mt-1">Kyle M. Bondo</span>
      </a>
      <p class="text-lg text-zinc-600 dark:text-zinc-300 mt-3 font-bold">Dent the Universe.&trade;</p>
      <p class="text-sm text-zinc-400 dark:text-zinc-200 mt-3">@ Copyright 2023. All Rights Reserved.</p>
    </div>
    <div class="grid grid-cols-2 gap-8 sm:gap-6 sm:space-x-10 text-base">
      <div>
        <h2 class="mb-6 text-sm text-zinc-900 uppercase dark:text-white">Projects</h2>
        <ul class="text-zinc-800 dark:text-zinc-300">
          <li class="mb-4">
            <a href="https://oncetold.us" class="hover:underline" target="_blank">Oncetold</a>
          </li>
          <li>
            <a href="https://waryankee.com" class="hover:underline" target="_blank">War Yankee</a>
          </li>
        </ul>
      </div>
      <div>
        <h2 class="mb-6 text-sm text-zinc-900 uppercase dark:text-white">Follow</h2>
        <ul class="text-zinc-800 dark:text-zinc-300">
          <li class="mb-4">
            <a href="https://github.com/gagglepod" class="hover:underline" target="_blank">GitHub</a>
          </li>
          <li>
            <a href="https://www.linkedin.com/in/kylebondo/" class="hover:underline" target="_blank">LinkedIn</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</footer>
